# ── Google Vertex AI ─────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to your GCP service account JSON (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# ── PostgreSQL (pgvector-container) ──────────────────────────────────────────
PG_HOST=localhost
PG_PORT=6024
PG_USER=langchain
PG_PASSWORD=langchain
PG_DB=hm_fashion

# ── Arize AX OTEL tracing (optional) ─────────────────────────────────────────
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=text-to-sql-agent
ARIZE_COLLECTOR_ENDPOINT=https://otlp.eu-west-1a.arize.com/v1
